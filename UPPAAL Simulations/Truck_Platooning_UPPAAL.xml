<!DOCTYPE nta PUBLIC '-//Uppaal Team//DTD Flat System 1.6//EN' 'http://www.it.uu.se/research/group/darts/uppaal/flat-1_6.dtd'>
<nta>
	<declaration>// Place global declarations here.
// ===== Timing constants (1 unit = 10 ms; rescaled for tractable verification) =====
const int T_HB       = 10;   // heartbeat period (lead emits every 100 ms)
const int T_LINKLOSS = 30;   // no heartbeat for this long =&gt; link declared lost
const int T_FALLBACK = 20;   // must reach safe independent driving within this after link loss
const int T_NOTIFY   = 10;   // JOIN/LEAVE notification latency bound (&lt; 100 ms)
const int T_SYNC     = 2;    // 50 Hz speed synchronization period
const int T_GAP_MAX  = 50;   // gap-creation deadline; distance-driven, so small ceiling is exact for untimed props  // gap must be created within 5 s

// ===== Distances (metres, abstract integers) =====
const int D_MIN = 10;         // minimum safe inter-vehicle gap
const int D_GAP = 50;         // target departure gap

// ===== Fleet size =====
const int N = 2;              // number of leaving trucks already in the platoon
typedef int[0, N-1] lv_id_t;  // leaving-truck identifier

// ===== Channels =====
chan join_req, join_appr;              // joining handshake
chan leave_req[N], leave_appr[N];      // per-truck leaving handshake (no cross-truck contention)
broadcast chan heartbeat;              // lead -&gt; follower(s), non-blocking
broadcast chan link_lost;              // watchdog raises this

// ===== Shared state =====
bool jt_coupled = false;               // joining truck in platoon
bool lv_coupled[N] = { true, true };   // each leaving truck starts as an existing member
int[0, 100] gap = D_MIN + 2;           // platoon link gap (watchdog / joining side)
int[0, 100] lgap[N] = { D_MIN+2, D_MIN+2 };  // per-truck departure gap (independent)

// ===== Scenario-coverage flags (for the "play all three" witness trace) =====
bool saw_couple    = false;   // set when a truck completes coupling
bool saw_depart    = false;   // set when a truck completes decoupling
bool saw_emergency = false;   // set when watchdog reaches emergency braking</declaration>
	<template>

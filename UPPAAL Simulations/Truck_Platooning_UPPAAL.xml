	<template>
		<name>LeavingTruck</name>
		<parameter>const lv_id_t id</parameter>
		<declaration>clock x;   // phase clock (notification bound)
clock g;   // gap-creation clock</declaration>
		<location id="id42" x="-59" y="-280">
			<name x="-93" y="-314">InPlatoon</name>
		</location>
		<location id="id43" x="-365" y="-280">
			<name x="-493" y="-297">WaitLeaveAppr</name>
			<label kind="invariant" x="-493" y="-280">x &lt;= T_NOTIFY</label>
		</location>
		<location id="id44" x="-59" y="-25">
			<name x="-42" y="-67">GapCreation</name>
			<label kind="invariant" x="-42" y="-50">g &lt;= T_GAP_MAX</label>
		</location>
		<location id="id45" x="161" y="-280">
			<name x="110" y="-314">SafetyVerify</name>
			<committed/>
		</location>
		<location id="id46" x="433" y="-280">
			<name x="399" y="-314">Departed</name>
		</location>
		<init ref="id42"/>
		<transition id="id47">
			<source ref="id45"/>
			<target ref="id42"/>
			<label kind="guard" x="8" y="-272">lgap[id] &lt; D_GAP</label>
		</transition>
		<transition id="id48">
			<source ref="id45"/>
			<target ref="id46"/>
			<label kind="guard" x="212" y="-272">lgap[id] &gt;= D_GAP</label>
			<label kind="assignment" x="212" y="-255">lv_coupled[id]=false, x=0, saw_depart=true</label>
		</transition>
		<transition id="id49">
			<source ref="id44"/>
			<target ref="id42"/>
			<label kind="guard" x="-51" y="-170">g &gt;= T_GAP_MAX</label>
			<label kind="assignment" x="-51" y="-153">g=0</label>
		</transition>
		<transition id="id50">
			<source ref="id44"/>
			<target ref="id45"/>
			<label kind="guard" x="170" y="-170">g &lt;= T_GAP_MAX &amp;&amp; lgap[id] &gt;= D_GAP</label>
			<label kind="assignment" x="170" y="-153">x=0</label>
			<nail x="161" y="-25"/>
		</transition>
		<transition id="id51">
			<source ref="id44"/>
			<target ref="id44"/>
			<label kind="guard" x="-153" y="68">g &lt; T_GAP_MAX &amp;&amp; lgap[id] &lt; D_GAP</label>
			<label kind="assignment" x="-153" y="85">lgap[id]=lgap[id]+10</label>
			<nail x="-153" y="8"/>
			<nail x="-153" y="68"/>
			<nail x="34" y="68"/>
			<nail x="34" y="8"/>
		</transition>
		<transition id="id52">
			<source ref="id43"/>
			<target ref="id44"/>
			<label kind="synchronisation" x="-357" y="-170">leave_appr[id]?</label>
			<label kind="assignment" x="-357" y="-153">g=0</label>
			<nail x="-365" y="-25"/>
		</transition>
		<transition id="id53">
			<source ref="id42"/>
			<target ref="id43"/>
			<label kind="synchronisation" x="-255" y="-272">leave_req[id]!</label>
			<label kind="assignment" x="-255" y="-255">x=0</label>
		</transition>
	</template>
	<system>// Place template instantiations here.
jt  = JoiningTruck();
lt  = LeadTruck();
lv0 = LeavingTruck(0);   // the truck that was already present
lv1 = LeavingTruck(1);   // extra member of the standing platoon
wd  = Watchdog();

// List one or more processes to be composed into a system.
system jt, lt, lv0, lv1, wd;
</system>
	<queries>
		<option key="--learning-method" value="2"/>
		<option key="--diagnostic" value="1"/>
		<query>
			<formula>A[] not deadlock
</formula>
			<comment>No deadlock even with three leaving trucks contending for the leader (per-truck channels + serialised leader + Departed idle self-loop).</comment>
			<option key="--learning-method" value="2"/>
			<option key="--diagnostic" value="0"/>
		</query>
		<query>
			<formula>E&lt;&gt; jt.PlatoonActive
</formula>
			<comment/>
		</query>
		<query>
			<formula>E&lt;&gt; jt.Independent
</formula>
			<comment/>
		</query>
		<query>
			<formula>A[] (jt.WaitApproval imply jt.x &lt;= T_NOTIFY)
</formula>
			<comment/>
		</query>
		<query>
			<formula>E&lt;&gt; lv0.Departed
</formula>
			<comment/>
		</query>
		<query>
			<formula>E&lt;&gt; lv0.InPlatoon
</formula>
			<comment/>
		</query>
		<query>
			<formula>E&lt;&gt; (lv0.Departed &amp;&amp; lv1.Departed &amp;&amp; lv2.Departed)
</formula>
			<comment>All three standing members can complete their departures.</comment>
		</query>
		<query>
			<formula>A[] (lv0.WaitLeaveAppr imply lv0.x &lt;= T_NOTIFY)
</formula>
			<comment>Leave notification stays within bound for truck 0.</comment>
		</query>
		<query>
			<formula>A[] (lv1.WaitLeaveAppr imply lv1.x &lt;= T_NOTIFY)
</formula>
			<comment>Leave notification stays within bound for truck 1 (no starvation from contention).</comment>
		</query>
		<query>
			<formula>A[] (lv2.WaitLeaveAppr imply lv2.x &lt;= T_NOTIFY)
</formula>
			<comment>Leave notification stays within bound for truck 2 (no starvation from contention).</comment>
		</query>
		<query>
			<formula>lv0.SafetyVerify --&gt; (lv0.Departed || lv0.InPlatoon)
</formula>
			<comment/>
		</query>
		<query>
			<formula>E&lt;&gt; wd.SafeFallBack
</formula>
			<comment/>
		</query>
		<query>
			<formula>A[] (wd.LinkLost imply wd.f &lt;= T_FALLBACK)
</formula>
			<comment/>
		</query>
		<query>
			<formula>wd.LinkLost --&gt; wd.Platooning
</formula>
			<comment/>
		</query>
		<query>
			<formula>wd.LinkLost --&gt; wd.SafeFallBack
</formula>
			<comment/>
		</query>
		<query>
			<formula>E&lt;&gt; wd.EmergencyBrake</formula>
			<comment/>
		</query>
		<query>
			<formula>E&lt;&gt; jt.SafetyCheck</formula>
			<comment/>
		</query>
		<query>
			<formula>E&lt;&gt; lv0.SafetyVerify</formula>
			<comment/>
		</query>
		<query>
			<formula>E&lt;&gt; (saw_couple &amp;&amp; saw_depart &amp;&amp; saw_emergency)</formula>
			<comment>Witness trace that exercises all three scenarios (coupling + decoupling + comm-error/emergency)</comment>
		</query>
	</queries>
</nta>

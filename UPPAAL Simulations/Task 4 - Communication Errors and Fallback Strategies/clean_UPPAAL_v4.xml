			<label kind="assignment" x="34" y="-297">jt_coupled=false, x=0</label>
			<nail x="25" y="-314"/>
		</transition>
		<transition id="id6">
			<source ref="id0"/>
			<target ref="id1"/>
			<label kind="guard" x="34" y="-26">s &gt;= T_SYNC &amp;&amp; sync_count &gt;= 3</label>
			<label kind="assignment" x="34" y="-9">jt_coupled=true, x=0</label>
			<nail x="25" y="8"/>
		</transition>
		<transition id="id7">
			<source ref="id0"/>
			<target ref="id0"/>
			<label kind="guard" x="-272" y="85">s &gt;= T_SYNC &amp;&amp; sync_count &lt; 3</label>
			<label kind="assignment" x="-272" y="68">s=0, gap=D_MIN+2, sync_count++</label>
			<nail x="-306" y="68"/>
			<nail x="0" y="68"/>
		</transition>
		<transition id="id8">
			<source ref="id2"/>
			<target ref="id3"/>
			<label kind="guard" x="-331" y="-221">gap &lt; D_MIN || gap &gt; D_GAP</label>

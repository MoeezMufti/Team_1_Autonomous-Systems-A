		<transition id="id6">
			<source ref="id0"/>
			<target ref="id1"/>
			<label kind="guard" x="-85" y="42">s &gt;= T_SYNC &amp;&amp; sync_count &gt;= 3</label>
			<label kind="assignment" x="-144" y="25">jt_coupled=true, x=0</label>
